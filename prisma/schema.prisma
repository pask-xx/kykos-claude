generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== ENUMS ==================

enum Role {
  DONOR
  RECIPIENT
  INTERMEDIARY
  ADMIN
}

enum OperatorRole {
  ADMIN
  GESTORE_RICHIESTE
  GESTORE_OGGETTI
  GESTORE_VOLONTARI
  OPERATORE
}

enum OperatorPermission {
  RECIPIENT_AUTHORIZE
  OBJECT_RECEIVE
  OBJECT_DELIVER
  VOLUNTEER_MANAGE
  REQUEST_PROXY
  ORGANIZATION_ADMIN
}

enum OrgType {
  CHARITY
  CHURCH
  ASSOCIATION
}

enum Category {
  FURNITURE
  ELECTRONICS
  CLOTHING
  BOOKS
  KITCHEN
  SPORTS
  TOYS
  OTHER
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ObjectStatus {
  AVAILABLE
  RESERVED
  DEPOSITED
  DONATED
  CANCELLED
  BLOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DonorLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum NotificationType {
  // User notifications
  DONATION_CONFIRMED
  REQUEST_APPROVED
  REQUEST_REJECTED
  OBJECT_AVAILABLE
  OBJECT_RESERVED
  OBJECT_DELIVERED
  OBJECT_DEPOSITED
  OBJECT_CANCELLED
  REPORT_RECEIVED
  REPORT_RESOLVED
  MESSAGE_FROM_OPERATOR
  // Operator notifications
  NEW_REQUEST
  NEW_REPORT
  REQUEST_EXPIRED
  OBJECT_BLOCKED
  // Goods request notifications
  GOODS_REQUEST_CREATED
  GOODS_REQUEST_APPROVED
  GOODS_REQUEST_REJECTED
  GOODS_REQUEST_FULFILLED
  GOODS_OFFER_RECEIVED
  // Cause notifications
  CAUSE_MESSAGE
  // Street operator notifications
  STREET_OBJECT_DEPOSITED
}

enum RequestType {
  GOODS
  SERVICES
}

enum LegalDocumentType {
  TERMS
  PRIVACY
}

enum LegalDocumentStatus {
  scheduled
  active
  archived
}

enum GoodsRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum GoodsOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum RecipientType {
  USER
  OPERATOR
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  WITHDRAWN
}

enum AdesioneStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MultiAvailabilityStatus {
  OPEN
  CLOSED
  EXHAUSTED
}

enum MultiAvailabilityRequestStatus {
  PENDING
  ASSIGNED
  REJECTED
  FULFILLED
  CANCELLED
}

// ================== MODELS ==================

model User {
  id           String   @id @default(cuid())
  authUserId   String?  @unique // Supabase Auth user ID
  email        String   @unique
  name         String // Keep for backward compat
  nickname     String? // User-chosen or auto-generated fantasy name, used for display to intermediaries
  passwordHash String? // Nullable - null for Supabase Auth users, kept for migration
  role         Role     @default(DONOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Common optional fields
  latitude    Float?
  longitude   Float?
  firstName   String?
  lastName    String?
  birthDate   DateTime?
  fiscalCode  String?
  address     String?
  houseNumber String?
  cap         String?
  city        String?
  province    String?

  // Recipient fields
  referenceEntityId    String?
  referenceEntity      Organization? @relation("RecipientReference", fields: [referenceEntityId], references: [id])
  isee                 Decimal?
  needScore            Int           @default(50) // 0-100, indice di bisogno, editabile da admin ente
  authorized           Boolean       @default(false)
  authorizedAt         DateTime?
  emailConfirmed       Boolean       @default(false)
  emailConfirmedAt     DateTime?
  canProvideServices   Boolean       @default(false)
  canProvideServicesAt DateTime?
  canRequestGoods      Boolean       @default(true)
  canRequestServices   Boolean       @default(false)
  isStreetManaged      Boolean       @default(false) // true = senza account, gestito da street operators
  profileImageUrl      String?       // URL pubblica della foto profilo

  // Diocese (for DONOR and RECIPIENT, organization diocese is stored on Organization model)
  dioceseId String?
  diocese   Diocese? @relation(fields: [dioceseId], references: [id])

  // Donor relations
  donatedObjects Object[]      @relation("DonorObjects")
  donorProfile   DonorProfile?

  // Deactivation (B2: soft-delete invece di user.delete, per preservare lo storico)
  deactivatedAt     DateTime?
  deactivatedActions String[]  @default([]) // log delle azioni di cascade per audit

  // Recipient relations
  requests          Request[]  @relation("RecipientRequests")
  receivedDonations Donation[] @relation("ReceivedDonations")

  // Intermediary relation
  intermediaryOrg Organization?

  // Donation history
  donations Donation[] @relation("DonationDonor")

  // Reports
  reportsCreated Report[] @relation("ReporterUser")

  // Notifications
  notifications Notification[] @relation("NotificationUser")

  // Goods requests
  goodsRequests  GoodsRequest[] @relation("GoodsRequestBeneficiary")
  goodsOffers    GoodsOffer[]   @relation("GoodsOfferGiver")
  goodsFulfilled GoodsRequest[] @relation("GoodsRequestFulfiller")

  // Volunteer associations
  volunteerAssociations VolunteerAssociation[]

  // Multi availability requests
  multiAvailabilityRequests MultiAvailabilityRequest[]

  // Cause participation
  causeParticipations CauseParticipant[]

  // Street operators che gestiscono questo beneficiario (se isStreetManaged=true)
  managedByStreetOperators StreetOperatorBeneficiary[]

  // GDPR art. 7: tracciamento del consenso a privacy + termini.
  // Una entry per (utente, documento, versione). L'unicità permette di dimostrare
  // in caso di audit Garante cosa l'utente ha accettato e quando.
  legalConsents LegalConsent[]

  // Admin ha caricato versioni di documenti legali
  uploadedLegalDocs LegalDocumentVersion[] @relation("LegalDocUploader")
  // Audit log delle azioni admin
  adminActions AdminAction[] @relation("AdminActions")

  @@map("users")
}

model LegalConsent {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType  LegalDocumentType
  version       String            // es. "1.0"
  documentHash  String            // SHA-256 del PDF al momento dell'accettazione
  acceptedAt    DateTime          @default(now())
  ipAddress     String?           // opzionale, prova legale
  userAgent     String?           // opzionale, prova legale

  @@unique([userId, documentType, version]) // idempotente: stesso user+doc+version
  @@index([userId])
  @@index([documentType, version])
}

/// Storico immutabile di tutti i PDF (Privacy/ToS) caricati dall'admin.
/// Una sola riga per (type, version) con status 'active' — la "versione
/// corrente" che gli utenti devono accettare. Il flusso di transizione è:
///   scheduled (appena caricato, non ancora visibile) → active (pubblicato)
///   active → archived (quando sostituito da un nuovo active)
/// Solo le righe 'scheduled' sono cancellabili, per preservare la prova
/// storica in caso di audit Garante. Vedi routes /api/admin/legal/*.
model LegalDocumentVersion {
  id           String              @id @default(cuid())
  type         LegalDocumentType
  version      String              // semver-like: "1.0", "1.1", "2.0", ...
  hash         String              // SHA-256 del PDF, calcolato server-side al upload
  storagePath  String              // path nel bucket Supabase Storage
  fileSize     Int                 // bytes
  status       LegalDocumentStatus @default(scheduled)
  uploadedById String
  uploadedBy   User                @relation("LegalDocUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime            @default(now())
  publishedAt  DateTime?           // null finché status = scheduled
  archivedAt   DateTime?           // null finché status = active
  notes        String?             // changelog opzionale (es. "Riformulazione art. 5")

  @@unique([type, version])        // un solo PDF per type+version
  @@index([type, status])          // query "versione attiva per type"
  @@index([uploadedById])
  @@map("legal_document_versions")
}

/// Audit log: chi ha fatto cosa quando sulle risorse admin.
/// In V1 usato principalmente per legal_doc.* (upload, publish, restore, delete).
/// Crescerà in V2 con moderation, operator management, ecc.
model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])
  action     String   // "legal_doc.upload", "legal_doc.publish", "legal_doc.restore", "legal_doc.delete"
  targetType String?  // es. "LegalDocumentVersion"
  targetId   String?
  metadata   Json?    // dettagli: { fromVersion, toVersion, type, ... }
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_actions")
}

model Diocese {
  id        String @id @default(cuid())
  name      String @unique // e.g., "Diocesi di Roma", "Arcidiocesi di Milano"
  seat      String // e.g., "Roma", "Milano"
  latitude  Float
  longitude Float

  organizations Organization[]
  users         User[]

  @@map("dioceses")
}

model Organization {
  id                          String   @id @default(cuid())
  code                        String   @unique
  name                        String
  type                        OrgType
  vatNumber                   String?
  latitude                    Float?
  longitude                   Float?
  address                     String?
  houseNumber                 String?
  cap                         String?
  city                        String?
  province                    String?
  phone                       String?
  email                       String?
  verified                    Boolean  @default(false)
  autoApproveRequests         Boolean  @default(false) // Oggetti dal donatore
  autoApproveGoodsRequests    Boolean  @default(true) // Richieste beni
  autoApproveServicesRequests Boolean  @default(false) // Richieste servizi
  hoursInfo                   String?  @map("hours_info") @db.Text // Rich text with opening hours and instructions
  printLabel                  Boolean  @default(false) @map("printlabel")
  labelSize                   String   @default("50x30") @map("labelsize")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dioceseId String?
  diocese   Diocese? @relation(fields: [dioceseId], references: [id])

  operators Operator[]

  objects              Object[]
  requests             Request[]
  payments             Payment[]
  authorizedRecipients User[]         @relation("RecipientReference")
  reports              Report[]
  goodsRequests        GoodsRequest[]

  // Volunteer associations
  volunteerAssociations VolunteerAssociation[]

  // Multi availability
  multiAvailabilities MultiAvailability[]

  // Causes
  causes Cause[]

  @@map("organizations")
}

// ================== GEOGRAPHY ==================

model Province {
  id    String @id @default(cuid())
  sigla String @unique // e.g., "AG", "TO", "RM"
  name  String // e.g., "Agrigento", "Torino", "Roma"

  comuni Comune[]

  @@map("provinces")
}

model Comune {
  id        String @id @default(cuid())
  istat     String @unique // ISTAT code, e.g., "1001"
  name      String // e.g., "Agliè", "Roma"
  latitude  Float?
  longitude Float?

  provinceSigla String
  province      Province @relation(fields: [provinceSigla], references: [sigla])

  @@map("comunes")
}

model Object {
  id              String       @id @default(cuid())
  title           String
  description     String?
  category        Category
  condition       Condition
  status          ObjectStatus @default(AVAILABLE)
  imageUrls       String[]
  depositLocation String?      @map("deposit_location") // Scaffale/doposito dove è stato placed
  depositNotes    String?      @map("deposit_notes") // Note aggiuntive sulla consegna
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  donorId String
  donor   User   @relation("DonorObjects", fields: [donorId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  requests Request[]
  donation Donation?
  reports  Report[]

  @@index([donorId])
  @@index([status])
  @@map("objects")
}

model Request {
  id        String        @id @default(cuid())
  status    RequestStatus @default(PENDING)
  message   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  objectId String
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("RecipientRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  donation Donation?

  @@index([recipientId])
  @@index([recipientId, status])
  @@map("requests")
}

model Donation {
  id        String   @id @default(cuid())
  amount    Decimal  @default(1.00)
  currency  String   @default("EUR")
  createdAt DateTime @default(now())

  objectId String @unique
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  donorId String
  donor   User   @relation("DonationDonor", fields: [donorId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("ReceivedDonations", fields: [recipientId], references: [id], onDelete: Cascade)

  requestId String  @unique
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  @@index([recipientId])
  @@map("donations")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  donationId String?   @unique
  donation   Donation?

  @@map("payments")
}

model DonorProfile {
  id             String     @id @default(cuid())
  totalDonations Int        @default(0)
  totalObjects   Int        @default(0)
  level          DonorLevel @default(BRONZE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donor_profiles")
}

model Operator {
  id               String       @id @default(cuid())
  supabaseAuthId   String?      @unique // Supabase Auth user ID
  username         String // unique within organization (format: nome.cognome or nome.cognome.CODICE)
  email            String?
  phone            String?
  firstName        String
  lastName         String
  passwordHash     String?
  role             OperatorRole @default(OPERATORE)
  permissions      String[]     @default([]) // additional granular permissions
  active           Boolean      @default(true)
  isOfficeOperator Boolean      @default(true) // operatore d'ufficio (comportamento attuale)
  isStreetOperator Boolean      @default(false) // operatore di strada
  profileImageUrl  String?      // URL pubblica della foto profilo
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Notifications
  notifications Notification[] @relation("NotificationOperator")

  // Street operator: beneficiari gestiti
  managedBeneficiaries StreetOperatorBeneficiary[]

  @@unique([username])
  @@map("operators")
}

// Associa più street operators allo stesso beneficiario (turnazione/backup)
model StreetOperatorBeneficiary {
  id         String   @id @default(cuid())
  assignedAt DateTime @default(now())

  streetOperatorId String
  streetOperator   Operator @relation(fields: [streetOperatorId], references: [id], onDelete: Cascade)

  beneficiaryId String
  beneficiary   User   @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@unique([streetOperatorId, beneficiaryId])
  @@index([streetOperatorId])
  @@index([beneficiaryId])
  @@map("street_operator_beneficiaries")
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Report {
  id        String       @id @default(cuid())
  reason    String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  objectId String
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User   @relation("ReporterUser", fields: [reporterId], references: [id])

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  notifications Notification[]

  @@index([status])
  @@map("reports")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  data      String?          @map("data") @db.Text // JSON with extra data
  createdAt DateTime         @default(now())

  recipientType       RecipientType @default(USER)
  recipientUserId     String?
  recipientOperatorId String?

  recipientUser     User?     @relation("NotificationUser", fields: [recipientUserId], references: [id], onDelete: Cascade, map: "notification_user_fk")
  recipientOperator Operator? @relation("NotificationOperator", fields: [recipientOperatorId], references: [id], onDelete: Cascade, map: "notification_operator_fk")

  reportId String?
  report   Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@unique([recipientUserId, recipientOperatorId])
  @@index([recipientType, createdAt])
  @@index([read, createdAt])
  @@map("notifications")
}

model GoodsRequest {
  id          String             @id @default(cuid())
  title       String
  category    Category
  description String?            @map("description") @db.Text
  type        RequestType        @default(GOODS)
  status      GoodsRequestStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  beneficiaryId String
  beneficiary   User   @relation("GoodsRequestBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  fulfilledById String?
  fulfilledBy   User?     @relation("GoodsRequestFulfiller", fields: [fulfilledById], references: [id], onDelete: SetNull)
  fulfilledAt   DateTime?

  depositLocation String? @map("deposit_location") // Scaffale/dove è stato depositato
  depositNotes    String? @map("deposit_notes") // Note aggiuntive sulla consegna

  offers GoodsOffer[] @relation("GoodsOfferRequest")

  @@index([beneficiaryId])
  @@index([intermediaryId])
  @@index([status])
  @@map("goods_requests")
}

model GoodsOffer {
  id        String           @id @default(cuid())
  message   String?
  status    GoodsOfferStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  requestId String
  request   GoodsRequest @relation("GoodsOfferRequest", fields: [requestId], references: [id], onDelete: Cascade)

  offeredById String
  offeredBy   User   @relation("GoodsOfferGiver", fields: [offeredById], references: [id], onDelete: Cascade, map: "goods_offers_offeredBy_fk")

  imageUrls String[] @default([])

  @@index([requestId])
  @@map("goods_offers")
}

// PendingRegistration removed - now using Supabase Auth email confirmation

model VolunteerAssociation {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         VolunteerStatus @default(PENDING)
  skills         String[]        @default([]) // es. ["Distribuzione", "Trasporto", "Assistenza"]
  note           String?         @db.Text // Note testuali del candidato
  cvUrl          String? // URL del CV allegato
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@map("volunteer_associations")
}

model AdesioneEnte {
  id                String         @id @default(cuid())
  denominazione     String
  nomeReferente     String
  cognomeReferente  String
  telefono          String
  email             String
  indirizzo         String
  civico            String
  cap               String
  citta             String
  provincia         String?
  nota              String         @db.Text
  website           String?
  status            AdesioneStatus @default(PENDING)
  emailConfirmed    Boolean        @default(false)
  emailConfirmToken String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("adesione_enti")
}

model NotifyEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("notify_emails")
}

model MultiAvailability {
  id             String                  @id @default(cuid())
  title          String
  description    String?                 @db.Text
  category       Category
  imageUrls      String[]                @default([])
  availableQty   Int                     @default(1)
  assignedQty    Int                     @default(0)
  status         MultiAvailabilityStatus @default(OPEN)
  deadline       DateTime?
  exhaustMessage String?                 @db.Text
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  requests MultiAvailabilityRequest[]

  @@index([organizationId])
  @@index([status])
  @@map("multi_availabilities")
}

model MultiAvailabilityRequest {
  id                String                         @id @default(cuid())
  needScoreSnapshot Int
  requestedAt       DateTime                       @default(now())
  status            MultiAvailabilityRequestStatus @default(PENDING)
  qrCode            String?
  fulfilledAt       DateTime?
  notifiedAt        DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  multiAvailabilityId String
  multiAvailability   MultiAvailability @relation(fields: [multiAvailabilityId], references: [id], onDelete: Cascade)

  beneficiaryId String
  beneficiary   User   @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@unique([multiAvailabilityId, beneficiaryId])
  @@index([multiAvailabilityId])
  @@index([beneficiaryId])
  @@map("multi_availability_requests")
}

model Cause {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  imageUrls   String[]  @default([])
  targetQty   Int?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  participants CauseParticipant[]

  @@index([organizationId])
  @@map("causes")
}

model CauseParticipant {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())
  note     String?  @db.Text

  causeId String
  cause   Cause  @relation(fields: [causeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([causeId, userId])
  @@index([causeId])
  @@index([userId])
  @@map("cause_participants")
}
