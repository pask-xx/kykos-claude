generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== ENUMS ==================

enum Role {
  DONOR
  RECIPIENT
  INTERMEDIARY
  ADMIN
}

enum OperatorRole {
  ADMIN
  GESTORE_RICHIESTE
  GESTORE_OGGETTI
  GESTORE_VOLONTARI
  OPERATORE
}

enum OperatorPermission {
  RECIPIENT_AUTHORIZE
  OBJECT_RECEIVE
  OBJECT_DELIVER
  VOLUNTEER_MANAGE
  REQUEST_PROXY
  ORGANIZATION_ADMIN
}

enum OrgType {
  CHARITY
  CHURCH
  ASSOCIATION
}

enum Category {
  FURNITURE
  ELECTRONICS
  CLOTHING
  BOOKS
  KITCHEN
  SPORTS
  TOYS
  OTHER
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ObjectStatus {
  AVAILABLE
  RESERVED
  DONATED
  WITHDRAWN
  BLOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DonorLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum NotificationType {
  // User notifications
  DONATION_CONFIRMED
  REQUEST_APPROVED
  REQUEST_REJECTED
  OBJECT_AVAILABLE
  OBJECT_RESERVED
  OBJECT_DELIVERED
  OBJECT_WITHDRAWN
  REPORT_RECEIVED
  REPORT_RESOLVED
  MESSAGE_FROM_OPERATOR
  // Operator notifications
  NEW_REQUEST
  NEW_REPORT
  REQUEST_EXPIRED
  OBJECT_BLOCKED
  // Goods request notifications
  GOODS_REQUEST_CREATED
  GOODS_REQUEST_APPROVED
  GOODS_REQUEST_REJECTED
  GOODS_REQUEST_FULFILLED
  GOODS_OFFER_RECEIVED
}

enum RequestType {
  GOODS
  SERVICES
}

enum GoodsRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  CANCELLED
}

enum RecipientType {
  USER
  OPERATOR
}

// ================== MODELS ==================

model User {
  id           String   @id @default(cuid())
  authUserId   String?  @unique  // Supabase Auth user ID
  email        String   @unique
  name         String // Keep for backward compat
  passwordHash String?           // Nullable - null for Supabase Auth users, kept for migration
  role         Role     @default(DONOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Common optional fields
  latitude    Float?
  longitude   Float?
  firstName   String?
  lastName    String?
  birthDate   DateTime?
  fiscalCode  String?
  address     String?
  houseNumber String?
  cap         String?
  city        String?
  province    String?

  // Recipient fields
  referenceEntityId    String?
  referenceEntity      Organization? @relation("RecipientReference", fields: [referenceEntityId], references: [id])
  isee                 Decimal?
  authorized           Boolean       @default(false)
  authorizedAt         DateTime?
  emailConfirmed       Boolean       @default(false)
  emailConfirmedAt     DateTime?
  canProvideServices   Boolean       @default(false)
  canProvideServicesAt DateTime?
  canRequestGoods     Boolean       @default(true)
  canRequestServices  Boolean       @default(false)

  // Donor relations
  donatedObjects Object[]      @relation("DonorObjects")
  donorProfile   DonorProfile?

  // Recipient relations
  requests          Request[]  @relation("RecipientRequests")
  receivedDonations Donation[] @relation("ReceivedDonations")

  // Intermediary relation
  intermediaryOrg Organization?

  // Donation history
  donations Donation[] @relation("DonationDonor")

  // Reports
  reportsCreated Report[] @relation("ReporterUser")

  // Notifications
  notifications Notification[] @relation("NotificationUser")

  // Goods requests
  goodsRequests  GoodsRequest[] @relation("GoodsRequestBeneficiary")
  goodsOffers    GoodsOffer[]   @relation("GoodsOfferGiver")
  goodsFulfilled GoodsRequest[] @relation("GoodsRequestFulfiller")

  @@map("users")
}

model Organization {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  type                OrgType
  vatNumber           String?
  latitude            Float?
  longitude           Float?
  address             String?
  houseNumber         String?
  cap                 String?
  city                String?
  province            String?
  phone               String?
  email               String?
  verified                   Boolean  @default(false)
  autoApproveRequests       Boolean  @default(false) // Oggetti dal donatore
  autoApproveGoodsRequests  Boolean  @default(true)  // Richieste beni
  autoApproveServicesRequests Boolean @default(false) // Richieste servizi
  hoursInfo           String?  @map("hours_info") @db.Text // Rich text with opening hours and instructions
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  operators Operator[]

  objects              Object[]
  requests             Request[]
  payments             Payment[]
  authorizedRecipients User[]         @relation("RecipientReference")
  reports              Report[]
  goodsRequests        GoodsRequest[]

  @@map("organizations")
}

// ================== GEOGRAPHY ==================

model Province {
  id        String   @id @default(cuid())
  sigla     String   @unique  // e.g., "AG", "TO", "RM"
  name      String             // e.g., "Agrigento", "Torino", "Roma"

  comuni    Comune[]

  @@map("provinces")
}

model Comune {
  id         String   @id @default(cuid())
  istat     String   @unique  // ISTAT code, e.g., "1001"
  name      String              // e.g., "Agliè", "Roma"
  latitude  Float?
  longitude Float?

  provinceSigla String
  province      Province @relation(fields: [provinceSigla], references: [sigla])

  @@map("comunes")
}

model Object {
  id              String       @id @default(cuid())
  title           String
  description     String?
  category        Category
  condition       Condition
  status          ObjectStatus @default(AVAILABLE)
  imageUrls       String[]
  depositLocation String?      @map("deposit_location") // Scaffale/doposito dove è stato placed
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  donorId String
  donor   User   @relation("DonorObjects", fields: [donorId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  requests Request[]
  donation Donation?
  reports  Report[]

  @@index([donorId])
  @@index([status])
  @@map("objects")
}

model Request {
  id        String        @id @default(cuid())
  status    RequestStatus @default(PENDING)
  message   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  objectId String
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("RecipientRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  donation Donation?

  @@index([recipientId])
  @@index([recipientId, status])
  @@map("requests")
}

model Donation {
  id        String   @id @default(cuid())
  amount    Decimal  @default(1.00)
  currency  String   @default("EUR")
  createdAt DateTime @default(now())

  objectId String @unique
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  donorId String
  donor   User   @relation("DonationDonor", fields: [donorId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("ReceivedDonations", fields: [recipientId], references: [id], onDelete: Cascade)

  requestId String  @unique
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  @@index([recipientId])
  @@map("donations")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  donationId String?   @unique
  donation   Donation?

  @@map("payments")
}

model DonorProfile {
  id             String     @id @default(cuid())
  totalDonations Int        @default(0)
  totalObjects   Int        @default(0)
  level          DonorLevel @default(BRONZE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donor_profiles")
}

model Operator {
  id              String       @id @default(cuid())
  supabaseAuthId  String?      @unique  // Supabase Auth user ID
  username       String       // unique within organization (format: nome.cognome or nome.cognome.CODICE)
  email          String?
  phone          String?
  firstName      String
  lastName       String
  passwordHash   String?
  role           OperatorRole @default(OPERATORE)
  permissions    String[]     @default([]) // additional granular permissions
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Notifications
  notifications Notification[] @relation("NotificationOperator")

  @@unique([username])
  @@map("operators")
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Report {
  id        String       @id @default(cuid())
  reason    String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  objectId String
  object   Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User   @relation("ReporterUser", fields: [reporterId], references: [id])

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  notifications Notification[]

  @@index([status])
  @@map("reports")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  data      String?          @map("data") @db.Text // JSON with extra data
  createdAt DateTime         @default(now())

  recipientId       String
  recipientType     RecipientType @default(USER)
  recipientUser     User?         @relation("NotificationUser", fields: [recipientId], references: [id], onDelete: Cascade, map: "notification_user_fk")
  recipientOperator Operator?     @relation("NotificationOperator", fields: [recipientId], references: [id], onDelete: Cascade, map: "notification_operator_fk")

  reportId String?
  report   Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([recipientId, recipientType])
  @@index([read, createdAt])
  @@map("notifications")
}

model GoodsRequest {
  id          String             @id @default(cuid())
  title       String
  category    Category
  description String?            @map("description") @db.Text
  type        RequestType        @default(GOODS)
  status      GoodsRequestStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  beneficiaryId String
  beneficiary   User   @relation("GoodsRequestBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)

  intermediaryId String
  intermediary   Organization @relation(fields: [intermediaryId], references: [id])

  fulfilledById String?
  fulfilledBy   User?     @relation("GoodsRequestFulfiller", fields: [fulfilledById], references: [id], onDelete: SetNull)
  fulfilledAt   DateTime?

  offers GoodsOffer[] @relation("GoodsOfferRequest")

  @@index([beneficiaryId])
  @@index([intermediaryId])
  @@index([status])
  @@map("goods_requests")
}

model GoodsOffer {
  id        String   @id @default(cuid())
  message   String?
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId String
  request   GoodsRequest @relation("GoodsOfferRequest", fields: [requestId], references: [id], onDelete: Cascade)

  offeredById String
  offeredBy   User   @relation("GoodsOfferGiver", fields: [offeredById], references: [id], onDelete: Cascade, map: "goods_offers_offeredBy_fk")

  @@index([requestId])
  @@map("goods_offers")
}

