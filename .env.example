# Database (Supabase with PgBouncer)
DATABASE_URL="postgresql://postgres:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?connection_limit=1"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Auth
JWT_SECRET="kykos-secret-key-change-in-production"

# Supabase Service Key (for admin operations)
SUPABASE_SERVICE_KEY="your-service-key"
