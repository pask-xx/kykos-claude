# ============================================================================
# KYKOS — STAGING env (per eseguire script CLI in locale puntando a STAGING)
# ============================================================================
# Questo file NON contiene segreti reali. I valori segnaposto vanno
# sostituiti prima dell'uso. Per generare secret random, vedi i comandi
# in fondo al file.
#
# ISTRUZIONI:
#   1. Copia questo file: `cp .env.staging.template .env.staging`
#   2. Popola i valori (vedi "Dove recuperare" sotto per ciascuno)
#   3. Per eseguire: `cp .env.staging .env && npx tsx scripts/seed-legal-v1.ts`
#   4. Dopo: `cp .env.local .env` (o riavvia con il tuo flow di dev)
#
# ⚠️ Il file .env.staging NON va committato (è in .gitignore). I file
# .env*.template sono committati perché non contengono segreti.
# ============================================================================

# ---------------------------------------------------------------------------
# 1. DATABASE_URL — connessione Prisma al DB Supabase staging
# ---------------------------------------------------------------------------
# Dove: Vercel → Project → Settings → Environment Variables
#       colonna "Preview" (= staging) → riga "DATABASE_URL"
# Formato: postgresql://postgres:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres:CHANGE_ME_STAGING@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ---------------------------------------------------------------------------
# 2. NEXT_PUBLIC_SUPABASE_URL — URL pubblico del progetto Supabase staging
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Preview" → riga "NEXT_PUBLIC_SUPABASE_URL"
# Formato: https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://CHANGE_ME_REF.supabase.co"

# ---------------------------------------------------------------------------
# 3. NEXT_PUBLIC_SUPABASE_ANON_KEY — chiave pubblica (esposta al browser by design)
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Preview" → riga "NEXT_PUBLIC_SUPABASE_ANON_KEY"
# Formato: JWT che inizia con eyJ...
# Sicurezza: bassa (è "pubblica" per design, viene bundlata nel client JS).
NEXT_PUBLIC_SUPABASE_ANON_KEY="CHANGE_ME_STAGING_ANON_KEY_JWT"

# ---------------------------------------------------------------------------
# 4. SUPABASE_SERVICE_KEY / SUPABASE_SERVICE_ROLE_KEY — chiave con poteri admin
# ---------------------------------------------------------------------------
# ⚠️ NON è su Vercel. È un segreto separato del progetto Supabase.
# Dove: Supabase Dashboard → seleziona progetto STAGING
#       → sezione API keys → riga "service_role"
# Formato: JWT che inizia con eyJ...
# Sicurezza: CRITICA. Bypassa tutte le policy RLS. Trattala come password di root.
#
# Impostare lo STESSO valore per entrambe le variabili (inconsistenza
# nel codice: src/lib/supabase.ts legge SUPABASE_SERVICE_ROLE_KEY, altre
# route leggono SUPABASE_SERVICE_KEY — fix futuro).
SUPABASE_SERVICE_KEY="CHANGE_ME_STAGING_SERVICE_ROLE_KEY_JWT"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME_STAGING_SERVICE_ROLE_KEY_JWT"

# ---------------------------------------------------------------------------
# 5. JWT_SECRET — chiave di firma dei token di sessione KYKOS
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Preview" → riga "JWT_SECRET"
# ⚠️ Deve essere un valore random, NON un placeholder.
# Genera uno nuovo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# oppure:
#   openssl rand -base64 48
# NB: cambiarlo invalida tutte le sessioni attive. È il comportamento
# atteso: ruotare il secret = buttare i token vecchi.
JWT_SECRET="CHANGE_ME_RANDOM_48_BYTES_BASE64"

# ---------------------------------------------------------------------------
# Opzionali (per build/test app intera puntando a staging)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_BASE_URL="https://kykos-staging.vercel.app"
# RESEND_API_KEY=""
# GOOGLE_GEOCODING_API_KEY=""

# ============================================================================
# COMANDI UTILI
# ============================================================================
#
# Genera JWT_SECRET random (48 bytes base64):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
# Genera password DB random (24 caratteri):
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64').replace(/[+/=]/g, 'x'))"
#
# Verifica env attivo:
#   node -e "console.log(process.env.DATABASE_URL ? 'OK' : 'MANCANTE')"
#
# ============================================================================
