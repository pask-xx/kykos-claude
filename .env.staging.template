# ============================================================================
# KYKOS — STAGING env (per eseguire script CLI in locale puntando a STAGING)
# ============================================================================
# Questo file NON viene committato (è in .gitignore). Serve solo per
# eseguire scripts/seed-legal-v1.ts e altri script Prisma contro il DB
# di staging.
#
# Per popolare:
#   1. DATABASE_URL → Vercel → Project → Settings → Environment Variables
#      → cerca "DATABASE_URL" nella colonna "Staging"
#   2. NEXT_PUBLIC_SUPABASE_URL → Vercel → stessa posizione, colonna Staging
#   3. NEXT_PUBLIC_SUPABASE_ANON_KEY → Vercel → stessa posizione, colonna Staging
#   4. SUPABASE_SERVICE_KEY / SUPABASE_SERVICE_ROLE_KEY → Supabase Dashboard
#      (NON da Vercel, è un segreto separato, vedi sotto)
#   5. JWT_SECRET → Vercel → stessa posizione, colonna Staging
#
# Una volta popolato, esegui:
#   copy .env.staging .env
#   npx tsx scripts/seed-legal-v1.ts
#   # ... poi ripristina .env.local se vuoi tornare a development
# ============================================================================

# Database Supabase (Staging) — copia da Vercel
DATABASE_URL="postgresql://postgres:INSERISCI_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase (Staging) — copia da Vercel
NEXT_PUBLIC_SUPABASE_URL="https://INSERISCI_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="INSERISCI_ANON_KEY"

# Supabase service role (Staging) — copia da Supabase Dashboard
# ⚠️ NON è su Vercel. È un segreto separato.
# Dove trovarlo:
#   1. Supabase Dashboard → seleziona progetto STAGING
#   2. Settings → API
#   3. Sezione "Project API keys" → riga "service_role" (NON "anon")
#   4. Clicca "Reveal" e copia il valore
# Stesso valore per SUPABASE_SERVICE_KEY e SUPABASE_SERVICE_ROLE_KEY
# (vedi inconsistenza nel codice esistente)
SUPABASE_SERVICE_KEY="INSERISCI_SERVICE_ROLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="INSERISCI_SERVICE_ROLE_KEY"

# JWT — copia da Vercel
JWT_SECRET="INSERISCI_JWT_SECRET"

# Non servono per il seed, ma le metto per completezza se vuoi fare
