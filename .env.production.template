# ============================================================================
# KYKOS — PRODUCTION env (per eseguire script CLI in locale puntando a PROD)
# ============================================================================
# ⚠️ ATTENZIONE: questo file contiene chiavi di PRODUZIONE. Maneggiarlo
# con cura. Viene letto solo dagli script CLI che lanci tu manualmente.
# MAI committarlo, MAI stamparlo a log, MAI condividerlo.
#
# Per popolare:
#   1. DATABASE_URL → Vercel → Project → Settings → Environment Variables
#      → cerca "DATABASE_URL" nella colonna "Production"
#   2. NEXT_PUBLIC_SUPABASE_URL → Vercel → colonna Production
#   3. NEXT_PUBLIC_SUPABASE_ANON_KEY → Vercel → colonna Production
#   4. SUPABASE_SERVICE_KEY / SUPABASE_SERVICE_ROLE_KEY → Supabase Dashboard
#      del progetto di PRODUZIONE
#   5. JWT_SECRET → Vercel → colonna Production
#
# Una volta popolato, esegui:
#   copy .env.production .env
#   npx tsx scripts/seed-legal-v1.ts
# ============================================================================

# Database Supabase (Production) — copia da Vercel
DATABASE_URL="postgresql://postgres:INSERISCI_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase (Production) — copia da Vercel
NEXT_PUBLIC_SUPABASE_URL="https://INSERISCI_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="INSERISCI_ANON_KEY"

# Supabase service role (Production) — copia da Supabase Dashboard PRODUCTION
# ⚠️ Chiave con poteri illimitati sul DB di produzione. Trattala come
# una password di root. Se la committi per sbaglio, ruotala SUBITO.
SUPABASE_SERVICE_KEY="INSERISCI_SERVICE_ROLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="INSERISCI_SERVICE_ROLE_KEY"

# JWT — copia da Vercel
JWT_SECRET="INSERISCI_JWT_SECRET"
