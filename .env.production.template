# ============================================================================
# KYKOS — PRODUCTION env (per eseguire script CLI in locale puntando a PROD)
# ============================================================================
# ⚠️⚠️⚠️ ATTENZIONE ⚠️⚠️⚠️
# Questo file contiene chiavi di PRODUZIONE. Maneggiarlo con estrema cura.
# Viene letto solo dagli script CLI che lanci tu manualmente.
# MAI committarlo, MAI stamparlo a log, MAI condividerlo via chat/email.
# ============================================================================
#
# ISTRUZIONI:
#   1. Copia questo file: `cp .env.production.template .env.production`
#   2. Popola i valori (vedi "Dove recuperare" sotto per ciascuno)
#   3. Per eseguire: `cp .env.production .env && npx tsx scripts/seed-legal-v1.ts`
#   4. Dopo: `cp .env.local .env` (o riavvia con il tuo flow di dev)
#
# ⚠️ Il file .env.production NON va committato (è in .gitignore). I file
# .env*.template sono committati perché non contengono segreti.
# ============================================================================

# ---------------------------------------------------------------------------
# 1. DATABASE_URL — connessione Prisma al DB Supabase production
# ---------------------------------------------------------------------------
# Dove: Vercel → Project → Settings → Environment Variables
#       colonna "Production" → riga "DATABASE_URL"
# Formato: postgresql://postgres:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres:CHANGE_ME_PRODUCTION@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ---------------------------------------------------------------------------
# 2. NEXT_PUBLIC_SUPABASE_URL — URL pubblico del progetto Supabase production
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Production" → riga "NEXT_PUBLIC_SUPABASE_URL"
# Formato: https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://CHANGE_ME_REF.supabase.co"

# ---------------------------------------------------------------------------
# 3. NEXT_PUBLIC_SUPABASE_ANON_KEY — chiave pubblica (esposta al browser by design)
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Production" → riga "NEXT_PUBLIC_SUPABASE_ANON_KEY"
# Formato: JWT che inizia con eyJ...
NEXT_PUBLIC_SUPABASE_ANON_KEY="CHANGE_ME_PRODUCTION_ANON_KEY_JWT"

# ---------------------------------------------------------------------------
# 4. SUPABASE_SERVICE_KEY / SUPABASE_SERVICE_ROLE_KEY — chiave con poteri admin
# ---------------------------------------------------------------------------
# ⚠️⚠️ Chiave con poteri ILLIMITATI sul DB di produzione. Trattala come
# una password di root del database. Se la committi per sbaglio o la
# condividi: ruotala SUBITO su Supabase Dashboard.
# Dove: Supabase Dashboard → seleziona progetto PRODUCTION
#       → sezione API keys → riga "service_role"
# Formato: JWT che inizia con eyJ...
#
# Impostare lo STESSO valore per entrambe le variabili (inconsistenza
# nel codice, vedi todo).
SUPABASE_SERVICE_KEY="CHANGE_ME_PRODUCTION_SERVICE_ROLE_KEY_JWT"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME_PRODUCTION_SERVICE_ROLE_KEY_JWT"

# ---------------------------------------------------------------------------
# 5. JWT_SECRET — chiave di firma dei token di sessione KYKOS
# ---------------------------------------------------------------------------
# Dove: Vercel → Environment Variables → colonna "Production" → riga "JWT_SECRET"
# ⚠️ Deve essere un valore random, NON un placeholder.
# Genera uno nuovo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# oppure:
#   openssl rand -base64 48
# NB: cambiarlo invalida tutte le sessioni attive. Tutti gli utenti
# dovranno rifare login. Comportamento atteso per una rotazione.
JWT_SECRET="CHANGE_ME_RANDOM_48_BYTES_BASE64"

# ============================================================================
# COMANDI UTILI
# ============================================================================
#
# Genera JWT_SECRET random (48 bytes base64):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
# Genera password DB random (24 caratteri):
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64').replace(/[+/=]/g, 'x'))"
#
# ============================================================================
